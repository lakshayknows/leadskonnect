# ============================================================
# LeadsKonnect — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# Every integration degrades gracefully if its vars are missing
# (the app boots; that channel is just reported as "not configured").
# ============================================================

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 32+ char random string used to sign sessions / internal tokens
BETTER_AUTH_SECRET=

# ---- Database (PostgreSQL) ----
# e.g. postgresql://user:password@localhost:5432/leadskonnect
DATABASE_URL=

# ---- Redis (for BullMQ job queue / rate-limit counters) ----
# e.g. redis://localhost:6379
REDIS_URL=

# ---- Upstash QStash (serverless campaign queue — drains queued sends on Vercel) ----
# When set (and NEXT_PUBLIC_APP_URL is not localhost), queued sends are published to
# QStash, which HTTP-calls /api/qstash/process on schedule — no long-lived worker needed.
# Falls back to BullMQ/REDIS_URL locally. Get these from the Upstash QStash console.
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ---- Email: SMTP (Nodemailer) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="LeadsKonnect <no-reply@yourdomain.com>"
# DKIM (optional but recommended for deliverability)
DKIM_DOMAIN=
DKIM_KEY_SELECTOR=default
DKIM_PRIVATE_KEY=

# ---- Email: "Connect Gmail" via Google OAuth (one-click sending accounts) ----
# Google Cloud → OAuth 2.0 Client (Web). Enable the Gmail API. Consent screen in
# "Testing" mode + add yourself as a test user to skip verification. Authorized
# redirect URIs: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback (prod + localhost).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- WhatsApp: Twilio ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio WhatsApp sender, e.g. whatsapp:+14155238886 (sandbox) or your number
TWILIO_WHATSAPP_FROM=

# ---- LinkedIn ----
# Official API (org pages). Personal automation is browser-based (see docs/channels.md).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
# Browser automation session cookie (li_at) — use with extreme care, gray area
LINKEDIN_LI_AT=

# ---- AI agent (NVIDIA — OpenAI-compatible endpoint) ----
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Model MUST support function/tool calling (the agent uses tools).
# Known-good: meta/llama-3.3-70b-instruct  or  nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ---- Auth (optional, for user login) ----
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---- Rate-limit defaults (override the safe defaults if you must) ----
RL_EMAIL_PER_HOUR=40
RL_LINKEDIN_PER_DAY=20
RL_WHATSAPP_PER_DAY=250
