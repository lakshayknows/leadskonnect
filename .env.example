# ============================================================
# LeadsKonnect — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# Every integration degrades gracefully if its vars are missing
# (the app boots; that channel is just reported as "not configured").
# ============================================================

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 32+ char random string used to sign sessions / internal tokens
APP_SECRET=

# ---- Database (PostgreSQL) ----
# e.g. postgresql://user:password@localhost:5432/leadskonnect
DATABASE_URL=

# ---- Redis (for BullMQ job queue / rate-limit counters) ----
# e.g. redis://localhost:6379
REDIS_URL=

# ---- Email: SMTP (Nodemailer) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="LeadsKonnect <no-reply@yourdomain.com>"
# DKIM (optional but recommended for deliverability)
DKIM_DOMAIN=
DKIM_KEY_SELECTOR=default
DKIM_PRIVATE_KEY=

# ---- Email: Gmail API (OAuth2) — optional alternative to SMTP ----
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=

# ---- WhatsApp: Twilio ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio WhatsApp sender, e.g. whatsapp:+14155238886 (sandbox) or your number
TWILIO_WHATSAPP_FROM=

# ---- LinkedIn ----
# Official API (org pages). Personal automation is browser-based (see docs/channels.md).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
# Browser automation session cookie (li_at) — use with extreme care, gray area
LINKEDIN_LI_AT=

# ---- AI agent (NVIDIA — OpenAI-compatible endpoint) ----
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Model MUST support function/tool calling (the agent uses tools).
# Known-good: meta/llama-3.3-70b-instruct  or  nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ---- Auth (optional, for user login) ----
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---- Rate-limit defaults (override the safe defaults if you must) ----
RL_EMAIL_PER_HOUR=40
RL_LINKEDIN_PER_DAY=20
RL_WHATSAPP_PER_DAY=250
